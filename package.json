{
	"name": "@tammergard/eslint-config-base",
	"version": "6.1.1",
	"description": "A sharable ESLint config for JavaScript with personal preferences",
	"keywords": [
		"eslint",
		"eslint-config",
		"eslint10",
		"flat-config",
		"config",
		"style-guide",
		"javascript"
	],
	"homepage": "https://github.com/filiptammergard/eslint-config-base#readme",
	"bugs": {
		"url": "https://github.com/filiptammergard/eslint-config-base/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/filiptammergard/eslint-config-base.git"
	},
	"license": "MIT",
	"author": {
		"name": "Filip Tammergård",
		"email": "filip+npm@tammergard.se",
		"url": "https://tammergard.se"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./index.js"
		}
	},
	"main": "index.js",
	"types": "index.d.ts",
	"files": [
		"index.js",
		"index.d.ts"
	],
	"scripts": {
		"format": "prettier --write .",
		"format-check": "prettier --check .",
		"release": "pnpm changeset publish",
		"review": "pnpm install --frozen-lockfile && pnpm format-check && pnpm test",
		"test": "node --test test/config.test.js"
	},
	"dependencies": {
		"@eslint/js": "^10.0.1"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@tammergard/prettier-config": "^3.0.0",
		"eslint": "^10.4.0",
		"prettier": "^3.8.3"
	},
	"peerDependencies": {
		"eslint": ">=10.0.0"
	},
	"packageManager": "pnpm@10.33.2",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=24",
			"onFail": "error"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
